---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | DevToolkit"
  description="Get in touch with the DevToolkit team. Questions, suggestions, or collaboration requests welcome."
>
  <div class="flex min-h-[60vh] items-center justify-center px-4 py-16 sm:px-6">
    <div class="w-full max-w-md rounded-2xl border border-slate-200 bg-white p-10 shadow-sm text-center">
      <div class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-full bg-blue-100">
        <svg class="h-7 w-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </div>
      <h1 class="mb-3 text-3xl font-bold text-slate-900">Get in Touch</h1>
      <p class="mb-8 text-slate-500">
        Have a question, suggestion, or want to collaborate? Reach out — we read every message.
      </p>
      <a
        href="mailto:contact@devtoolkit.dev"
        class="inline-block rounded-lg bg-blue-500 px-8 py-3 font-semibold text-white transition hover:bg-blue-400"
      >
        contact@devtoolkit.dev
      </a>
      <p class="mt-6 text-sm text-slate-400">
        We typically respond within 1–2 business days.
      </p>
    </div>
  </div>
</BaseLayout>
