---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { tools } from '../../lib/tools';

---

<BaseLayout
  title="Developer Tools | DevToolkit"
  description="Free online developer tools for JSON formatting, validation, and conversion."
>
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-10 sm:py-12">
    <div class="mb-8 flex flex-col gap-1">
      <h1 class="text-2xl font-bold text-[var(--color-foreground)] sm:text-[32px]">Developer Tools</h1>
      <p class="text-sm text-[var(--color-muted-foreground)] sm:text-base">Free, fast, browser-based tools. No sign-up required.</p>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3">
      {tools.map((tool) => (
        <a
          href={`/tools/${tool.slug}`}
          class="group flex flex-col gap-2.5 rounded-lg border border-[var(--color-border)] bg-[var(--color-card)] p-4 transition-all hover:shadow-md sm:gap-3 sm:p-5"
        >
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-[var(--color-secondary)] sm:h-10 sm:w-10">
            <span class="font-mono text-xs font-semibold text-[var(--color-foreground)] sm:text-sm">
              {tool.icon}
            </span>
          </div>
          <h2 class="text-[15px] font-semibold text-[var(--color-foreground)] sm:text-base">{tool.name}</h2>
          <p class="text-[13px] leading-relaxed text-[var(--color-muted-foreground)] sm:text-sm">{tool.description}</p>
          <span class="text-[13px] font-medium text-[var(--color-primary)] sm:text-sm">Open tool →</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
