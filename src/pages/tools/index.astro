---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { tools } from '../../lib/tools';

const categories = [...new Set(tools.map(t => t.category))];
---

<BaseLayout
  title="Developer Tools | DevToolkit"
  description="Free online developer tools for JSON formatting, validation, and conversion."
>
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-10 sm:py-12">
    <div class="mb-6 flex flex-col gap-1">
      <h1 class="text-2xl font-bold text-[var(--color-foreground)] sm:text-[32px]">Developer Tools</h1>
      <p class="text-sm text-[var(--color-muted-foreground)] sm:text-base">Free, fast, browser-based tools. No sign-up required.</p>
    </div>

    <!-- Category Filter -->
    <div class="mb-6 flex flex-wrap gap-2" id="category-filter">
      <button
        type="button"
        data-category="all"
        class="category-btn active rounded-full px-3 py-1.5 text-xs font-medium transition-colors sm:text-sm bg-[var(--color-foreground)] text-[var(--color-background)]"
      >
        All ({tools.length})
      </button>
      {categories.map((cat) => (
        <button
          type="button"
          data-category={cat}
          class="category-btn rounded-full px-3 py-1.5 text-xs font-medium transition-colors sm:text-sm bg-[var(--color-secondary)] text-[var(--color-muted-foreground)] hover:text-[var(--color-foreground)]"
        >
          {cat} ({tools.filter(t => t.category === cat).length})
        </button>
      ))}
    </div>

    <div class="grid gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3" id="tools-grid">
      {tools.map((tool) => (
        <a
          href={`/tools/${tool.slug}`}
          data-category={tool.category}
          class="tool-card group flex flex-col gap-2.5 rounded-lg border border-[var(--color-border)] bg-[var(--color-card)] p-4 transition-all hover:shadow-md sm:gap-3 sm:p-5"
        >
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-[var(--color-secondary)] sm:h-10 sm:w-10">
            <span class="font-mono text-xs font-semibold text-[var(--color-foreground)] sm:text-sm">
              {tool.icon}
            </span>
          </div>
          <h2 class="text-[15px] font-semibold text-[var(--color-foreground)] sm:text-base">{tool.name}</h2>
          <p class="text-[13px] leading-relaxed text-[var(--color-muted-foreground)] sm:text-sm">{tool.description}</p>
          <span class="text-[13px] font-medium text-[var(--color-primary)] sm:text-sm">Open tool →</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('.category-btn');
  const cards = document.querySelectorAll('.tool-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.getAttribute('data-category');

      buttons.forEach(b => {
        b.classList.remove('active');
        b.classList.remove('bg-[var(--color-foreground)]', 'text-[var(--color-background)]');
        b.classList.add('bg-[var(--color-secondary)]', 'text-[var(--color-muted-foreground)]');
      });
      btn.classList.add('active');
      btn.classList.remove('bg-[var(--color-secondary)]', 'text-[var(--color-muted-foreground)]');
      btn.classList.add('bg-[var(--color-foreground)]', 'text-[var(--color-background)]');

      cards.forEach(card => {
        if (cat === 'all' || card.getAttribute('data-category') === cat) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
