---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)]">
  <div class="mx-auto flex max-w-7xl flex-col-reverse items-center gap-3 px-4 py-5 sm:flex-row sm:justify-between sm:px-10 sm:py-6">
    <p class="text-[11px] text-[var(--color-muted-foreground)] sm:text-[13px]">
      &copy; {year} DevToolkit
    </p>
    <nav class="flex gap-5 text-[12px] text-[var(--color-muted-foreground)] sm:gap-6 sm:text-[13px]">
      <a href="/about" class="transition-colors hover:text-[var(--color-foreground)]">About</a>
      <a href="/privacy" class="transition-colors hover:text-[var(--color-foreground)]">Privacy</a>
      <a href="/contact" class="transition-colors hover:text-[var(--color-foreground)]">Contact</a>
    </nav>
  </div>
</footer>
