---
interface Props {
  position: 'header' | 'sidebar' | 'in-content' | 'footer';
}

const { position } = Astro.props;
const adsenseId = import.meta.env.PUBLIC_ADSENSE_ID;

const minHeights: Record<string, string> = {
  header: 'min-h-[90px]',
  sidebar: 'min-h-[250px]',
  'in-content': 'min-h-[250px]',
  footer: 'min-h-[90px]',
};

const adFormats: Record<string, string> = {
  header: 'horizontal',
  sidebar: 'vertical',
  'in-content': 'fluid',
  footer: 'horizontal',
};
---

{adsenseId && (
  <div
    data-ad-slot={position}
    class:list={[minHeights[position], "w-full"]}
  >
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={adsenseId}
      data-ad-format={adFormats[position]}
      data-full-width-responsive="true"
    ></ins>
    <script is:inline>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
)}
