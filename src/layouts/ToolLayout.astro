---
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import StructuredData from '../components/StructuredData.astro';
import { tools } from '../lib/tools';

interface Props {
  title: string;
  description: string;
  toolName: string;
  toolUrl: string;
}

const { title, description, toolName, toolUrl } = Astro.props;
const currentSlug = Astro.url.pathname.replace(/^\/tools\//, '').replace(/\/$/, '');

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: toolName,
  url: toolUrl,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description,
};
---

<BaseLayout title={title} description={description}>
  <StructuredData data={structuredData} />
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-10 sm:py-8">
    <AdSlot position="header" />

    <!-- Tool Navigation Tabs -->
    <nav class="mb-6 flex gap-1 overflow-x-auto rounded-lg bg-[var(--color-secondary)] p-1">
      {tools.map((tool) => (
        <a
          href={`/tools/${tool.slug}`}
          class:list={[
            "whitespace-nowrap rounded-md px-3 py-2 text-sm font-medium transition-colors",
            currentSlug === tool.slug
              ? "bg-[var(--color-background)] text-[var(--color-foreground)] shadow-sm"
              : "text-[var(--color-muted-foreground)] hover:text-[var(--color-foreground)]"
          ]}
        >
          {tool.name.replace(' & Beautifier', '').replace(' Converter', '')}
        </a>
      ))}
    </nav>

    <div class="mb-1">
      <h1 class="text-2xl font-bold text-[var(--color-foreground)] sm:text-[28px]">{toolName}</h1>
      <p class="text-[14px] text-[var(--color-muted-foreground)] sm:text-[15px]">{description}</p>
    </div>
    <div class="mt-6">
      <slot name="tool" />
    </div>
    <AdSlot position="in-content" />
    <div class="prose prose-neutral mt-12 max-w-none prose-headings:font-semibold prose-headings:text-[var(--color-foreground)] prose-p:text-[var(--color-muted-foreground)] prose-a:text-[var(--color-primary)] prose-code:rounded prose-code:bg-[var(--color-secondary)] prose-code:px-1 prose-code:py-0.5 prose-code:font-mono prose-pre:bg-[#1e1e2e] prose-pre:text-slate-200 [&_pre_code]:bg-transparent [&_pre_code]:p-0">
      <slot name="content" />
    </div>
    <AdSlot position="footer" />
  </div>
</BaseLayout>
