---
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import StructuredData from '../components/StructuredData.astro';
import { tools } from '../lib/tools';

interface Props {
  title: string;
  description: string;
  toolName: string;
  toolUrl: string;
}

const { title, description, toolName, toolUrl } = Astro.props;
const currentSlug = Astro.url.pathname.replace(/^\/tools\//, '').replace(/\/$/, '');
const currentTool = tools.find(t => t.slug === currentSlug);

const iconMap: Record<string, string> = {
  'json-formatter': '{ }',
  'json-validator': '✓',
  'json-to-yaml': '⇄',
  'base64': 'B64',
  'url-encoder': '%20',
  'uuid-generator': '#',
  'hash-generator': '#!',
  'lorem-ipsum': 'Aa',
};

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: toolName,
  url: toolUrl,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description,
};
---

<BaseLayout title={title} description={description}>
  <StructuredData data={structuredData} />
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-10 sm:py-8">
    <AdSlot position="header" />

    <!-- Tool Dropdown Nav + Title -->
    <div class="mb-6 flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-3">
      <div class="group relative">
        <button
          type="button"
          class="tool-dropdown-trigger flex w-full items-center justify-between gap-2 rounded-md border border-[var(--color-input)] bg-[var(--color-background)] px-3 py-2 text-sm sm:w-[280px]"
          aria-haspopup="listbox"
        >
          <span class="flex items-center gap-2">
            <span class="flex h-7 w-7 items-center justify-center rounded-md bg-[var(--color-secondary)]">
              <span class="font-mono text-[10px] font-semibold text-[var(--color-foreground)]">{iconMap[currentSlug] || '{}'}</span>
            </span>
            <span class="font-medium text-[var(--color-foreground)]">{currentTool?.name.replace(' & Beautifier', '').replace(' Converter', '').replace(' / Decoder', '').replace(' Generator', '') || toolName}</span>
          </span>
          <svg class="h-4 w-4 text-[var(--color-muted-foreground)] transition-transform group-focus-within:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <!-- Dropdown Menu -->
        <div class="tool-dropdown-menu invisible absolute left-0 top-full z-50 mt-1 w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-background)] p-1 opacity-0 shadow-lg transition-all group-focus-within:visible group-focus-within:opacity-100 sm:w-[280px]">
          {tools.map((tool) => (
            <a
              href={`/tools/${tool.slug}`}
              class:list={[
                "flex items-center gap-2 rounded-md px-2.5 py-2 text-[13px] transition-colors",
                currentSlug === tool.slug
                  ? "bg-[var(--color-secondary)] font-medium text-[var(--color-foreground)]"
                  : "text-[var(--color-foreground)] hover:bg-[var(--color-secondary)]"
              ]}
            >
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded bg-[var(--color-secondary)]">
                <span class:list={["font-mono font-semibold", iconMap[tool.slug]?.length > 2 ? 'text-[8px]' : 'text-[10px]']}>
                  {iconMap[tool.slug] || '{}'}
                </span>
              </span>
              <span class="flex-1">{tool.name.replace(' & Beautifier', '').replace(' Converter', '')}</span>
              {currentSlug === tool.slug && (
                <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <div class="flex-1">
        <h1 class="text-xl font-bold text-[var(--color-foreground)] sm:text-[24px]">{toolName}</h1>
        <p class="text-[13px] text-[var(--color-muted-foreground)] sm:text-[14px]">{description}</p>
      </div>
    </div>

    <div>
      <slot name="tool" />
    </div>
    <AdSlot position="in-content" />
    <div class="prose prose-neutral mt-12 max-w-none prose-headings:font-semibold prose-headings:text-[var(--color-foreground)] prose-p:text-[var(--color-muted-foreground)] prose-a:text-[var(--color-primary)] prose-code:rounded prose-code:bg-[var(--color-secondary)] prose-code:px-1 prose-code:py-0.5 prose-code:font-mono prose-pre:bg-[#1e1e2e] prose-pre:text-slate-200 [&_pre_code]:bg-transparent [&_pre_code]:p-0">
      <slot name="content" />
    </div>
    <AdSlot position="footer" />
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('.tool-dropdown-trigger').forEach(btn => {
    btn.addEventListener('click', () => btn.focus());
  });
</script>
