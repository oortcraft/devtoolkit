---
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import StructuredData from '../components/StructuredData.astro';
import { tools } from '../lib/tools';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  relatedTools?: string[];
}

const { title, description, pubDate, updatedDate, relatedTools } = Astro.props;

const toolLinks = Object.fromEntries(
  tools.map((t) => [t.slug, { name: t.name, href: `/tools/${t.slug}` }])
);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  publisher: {
    '@type': 'Organization',
    name: 'DevToolkit',
    url: 'https://oortcraft.dev',
  },
};
---

<BaseLayout title={`${title} | DevToolkit`} description={description}>
  <StructuredData data={structuredData} />
  <article class="mx-auto max-w-4xl px-4 py-8 sm:px-6">
    <header class="mb-8">
      <h1 class="mb-2 text-4xl font-bold text-slate-900">{title}</h1>
      <time class="text-sm text-slate-500" datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {updatedDate && (
        <span class="ml-2 text-sm text-slate-400">
          (Updated: {updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })})
        </span>
      )}
    </header>
    <AdSlot position="header" />
    <div class="prose prose-slate max-w-none prose-headings:scroll-mt-20 prose-a:text-primary prose-code:rounded prose-code:bg-slate-100 prose-code:px-1 prose-code:py-0.5 prose-code:font-mono prose-pre:bg-[#1e1e2e] prose-pre:text-slate-200 [&_pre_code]:bg-transparent [&_pre_code]:p-0">
      <slot />
    </div>
    <AdSlot position="footer" />
    {relatedTools && relatedTools.length > 0 && (
      <div class="mt-12 rounded-lg border border-[var(--color-border)] bg-[var(--color-secondary)] p-4 sm:p-6">
        <h2 class="mb-3 text-sm font-semibold text-[var(--color-foreground)] sm:text-lg">Related Tools</h2>
        <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:gap-3">
          {relatedTools.map((slug) => {
            const tool = toolLinks[slug];
            return tool ? (
              <a href={tool.href} class="rounded-md border border-[var(--color-border)] bg-[var(--color-background)] px-4 py-2 text-center text-sm font-medium text-[var(--color-foreground)] transition-colors hover:bg-[var(--color-secondary)]">
                {tool.name} →
              </a>
            ) : null;
          })}
        </div>
      </div>
    )}
  </article>
</BaseLayout>
